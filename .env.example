# --- Database (required) ---
# Neon serverless Postgres, or Vercel Postgres. Both work with the Neon driver.
DATABASE_URL=postgres://user:password@your-host.neon.tech/dynamo?sslmode=require

# --- Access gate (optional) ---
# If set, the dashboard is behind HTTP Basic Auth: any username + this passcode.
# Leave unset to keep the dashboard open. /api/evaluate stays open either way (cron).
DASHBOARD_PASSCODE=coolsip-demo
